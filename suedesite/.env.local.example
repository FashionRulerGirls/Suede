# Copy this file to ".env.local" and fill in the values from your Supabase
# project → Settings → API. Do NOT commit .env.local.

# Public — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER ONLY — full access, bypasses row-level security. Never expose this
# in client code or commit it anywhere.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
